{
	"name": "emdash-inbox",
	"version": "0.1.0",
	"description": "Cloudflare Email Service transport and Inbox-by-Google-style mailbox UI for EmDash CMS",
	"keywords": [
		"emdash",
		"emdash-plugin",
		"cms",
		"email",
		"inbox",
		"mailbox",
		"cloudflare",
		"cloudflare-workers",
		"cloudflare-email"
	],
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/proverbiallemon/emdash-inbox.git"
	},
	"homepage": "https://github.com/proverbiallemon/emdash-inbox#readme",
	"bugs": {
		"url": "https://github.com/proverbiallemon/emdash-inbox/issues"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist",
		"src",
		"LICENSE",
		"NOTICE",
		"README.md"
	],
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts --out-dir dist",
		"typecheck": "tsc --noEmit",
		"validate": "emdash plugin validate --dir ."
	},
	"peerDependencies": {
		"emdash": "*"
	},
	"devDependencies": {
		"emdash": "^0.5.0",
		"tsdown": "^0.21.9",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"postal-mime": "^2.7.4"
	}
}
